# Firebase Configuration - Android
ANDROID_API_KEY=your_android_api_key
ANDROID_APP_ID=your_android_app_id

# Firebase Configuration - iOS
IOS_API_KEY=your_ios_api_key
IOS_APP_ID=your_ios_app_id
IOS_BUNDLE_ID=your_ios_bundle_id

# Firebase Configuration - General
# MESSAGING_SENDER_ID is your Firebase Project Number (found in Project Settings > General)
MESSAGING_SENDER_ID=your_messaging_sender_id
PROJECT_ID=your_project_id
STORAGE_BUCKET=your_storage_bucket.firebasestorage.app
